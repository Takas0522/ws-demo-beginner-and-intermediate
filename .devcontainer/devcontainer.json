// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/alpine
{
	"name": "Debian (.NET + Node.js + Docker)",
	// Dockerfile でイメージをビルド（apt パッケージ・Python 仮想環境を事前構築）
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/azure-cli:1": {},
		"ghcr.io/devcontainers/features/dotnet:2": {
			"version": "10.0"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "22"
		},
		// .NET Aspire の AppHost がホスト Docker デーモンでコンテナを起動できるようにする
		// moby は Debian trixie で非対応のため false に設定
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
			"moby": false
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"marp-team.marp-vscode",
				"ms-toolsai.jupyter",
				"ms-dotnettools.csdevkit",
				"ms-dotnettools.csharp",
				"ms-dotnettools.vscode-dotnet-runtime",
				"esbenp.prettier-vscode",
				"dbaeumer.vscode-eslint",
				"ms-azuretools.vscode-docker",
				"ms-python.python",
				"ms-python.vscode-python-envs",
				"ms-python.debugpy",
				"ms-python.vscode-pylance"
			]
		}
	},

	"postCreateCommand": "bash .devcontainer/post-create.sh",

	// ダッシュボードアプリ用ポート / Aspire Dashboard ポート
	// forwardPorts は VS Code のポートフォワーディング機能に依存するため、
	// ホストから直接アクセスするには appPort で Docker レベルのポートバインドを行う
	"appPort": [5000, 5001, 5002, 3001, 3002, 18888, 18889]
}
